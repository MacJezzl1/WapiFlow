{
  "name": "wapiflow",
  "version": "1.0.0",
  "description": "Open-source WhatsApp Business automation platform with flow builder, AI replies, and multi-tenant inbox",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/dashboard",
    "apps/website",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "license": "MIT",
  "author": "CapeChain Labs <info@capechainlabs.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/capechainnodes/wapiflow.git"
  }
}
